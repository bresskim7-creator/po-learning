    {
      "id": "snowman",
      "title": "꼬마 눈사람",
      "type": "poem",
      "week": "260305",
      "lines": [
        {
          "text": "한겨울에 밀짚 모자 꼬마 눈사람",
          "pronunciation": "한겨우레 밀찝 모자 꼬마 눈싸람",
          "rules": [
            "연음(겨울에→겨우레)",
            "경음화(밀짚→밀찝)",
            "경음화(눈사람→눈싸람)"
          ]
        },
        {
          "text": "눈썹이 우습구나 코도 삐뚤고",
          "pronunciation": "눈써비 우습꾸나 코도 삐뚤고",
          "rules": [
            "연음(눈썹이→눈써비)",
            "경음화(우습구나→우습꾸나)"
          ]
        },
        {
          "text": "거울을 보여 줄까 꼬마 눈사람",
          "pronunciation": "거우를 보여 줄까 꼬마 눈싸람",
          "rules": [
            "연음(거울을→거우를)",
            "경음화(눈사람→눈싸람)"
          ]
        },
        {
          "text": "하루 종일 우두커니 꼬마 눈사람",
          "pronunciation": "하루 종일 우두커니 꼬마 눈싸람",
          "rules": [
            "경음화(눈사람→눈싸람)"
          ]
        },
        {
          "text": "무엇을 생각하고 혼자 서느냐",
          "pronunciation": "무어슬 생가카고 혼자 선느냐",
          "rules": [
            "연음(무엇을→무어슬)",
            "격음화(생각하고→생가카고)",
            "비음화(서느냐→선느냐)"
          ]
        },
        {
          "text": "집으로 들어갈까 꼬마 눈사람",
          "pronunciation": "지브로 드러갈까 꼬마 눈싸람",
          "rules": [
            "연음(집으로→지브로)",
            "연음(들어갈까→드러갈까)",
            "경음화(눈사람→눈싸람)"
          ]
        }
      ],
      "focusWords": [
        "밀짚",
        "눈사람",
        "눈썹이",
        "무엇을",
        "생각하고",
        "집으로"
